@php
    $tabs = $page['tabs'] ?? [];
    $sampleValue = function ($column, $rowIndex = 0, $page = [], $tab = []) {
        $text = trim((string) $column);
        $code = $page['code'] ?? '00000';
        $prefix = strtoupper(substr(preg_replace('/[^A-Za-z0-9]/', '', $code), 0, 6));
        if (preg_match('/^(ID|??)$/i', $text)) return $rowIndex + 1;
        if (str_contains($text, '??')) return '<input type="checkbox">';
        if (str_contains($text, '??')) return $rowIndex === 0 ? 'https://promo' . ($rowIndex + 1) . '.example.com' : 'https://track' . ($rowIndex + 1) . '.example.com';
        if (str_contains($text, '??') || str_contains($text, '???')) return $rowIndex === 0 ? 'agent001 / A1001' : 'agent00' . ($rowIndex + 1) . ' / A100' . ($rowIndex + 1);
        if (str_contains($text, 'GA4')) return 'G-' . $prefix . 'GA4' . ($rowIndex + 1);
        if (str_contains($text, 'GTM')) return 'GTM-' . $prefix . ($rowIndex + 1);
        if (str_contains($text, '??') || str_contains($text, 'Facebook')) return 'FB-' . $prefix . 'PX' . ($rowIndex + 1);
        if (str_contains($text, '??') || str_contains($text, 'TikTok')) return 'TT-' . $prefix . 'PX' . ($rowIndex + 1);
        if (str_contains($text, 'Appsflyer')) return 'AF-' . $prefix . '-APP' . ($rowIndex + 1);
        if (str_contains($text, 'Adjust') || str_contains($text, 'app_token')) return 'adj_' . strtolower($prefix) . '_token_' . ($rowIndex + 1);
        if (str_contains($text, 'token') || str_contains($text, 'Token')) return strtolower($prefix) . '_token_' . ($rowIndex + 1);
        if (str_contains($text, 'idfa')) return 'idfa';
        if (str_contains($text, 'adid')) return 'adid';
        if (str_contains($text, 'gps_adid')) return 'gps_adid';
        if (str_contains($text, '??') || str_contains($text, '??')) return '<span class="badge badge-success">??</span>';
        if (str_contains($text, 'HTTPS')) return '<span class="badge badge-success">???</span>';
        if (str_contains($text, '??')) return '<span class="badge badge-info">??</span>';
        if (str_contains($text, '??')) return '<span class="badge badge-primary">??</span>';
        if (str_contains($text, '??') || str_contains($text, '??')) return number_format(($rowIndex + 1) * 128);
        if (str_contains($text, '??')) return date('Y-m-d H:i', strtotime('-' . ($rowIndex + 2) . ' hours'));
        if (str_contains($text, '??')) return $rowIndex === 0 ? '??????' : '??????';
        if (str_contains($text, '??')) return '<span class="text-primary">????</span>';
        if (str_contains($text, '??')) return '<button class="btn btn-xs btn-primary" type="button">??</button> <button class="btn btn-xs btn-default" type="button">??</button> <button class="btn btn-xs btn-danger" type="button">??</button>';
        if (str_contains($text, '??')) return ($tab['title'] ?? $page['title'] ?? '??') . ' ' . ($rowIndex + 1);
        if (str_contains($text, '??')) return $rowIndex === 0 ? '????' : '?????';
        if (str_contains($text, '??') || str_contains($text, '??')) return number_format(($rowIndex + 1) * 1000, 2);
        return $text . ' ' . ($rowIndex + 1);
    };
    $renderRows = function ($columns, $count = 2, $page = [], $tab = []) use ($sampleValue) {
        $html = '';
        for ($i = 0; $i < $count; $i++) {
            $html .= '<tr>';
            foreach ($columns as $column) {
                $html .= '<td>' . $sampleValue($column, $i, $page, $tab) . '</td>';
            }
            $html .= '</tr>';
        }
        return $html;
    };
@endphp

